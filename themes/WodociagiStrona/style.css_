    #site-header ul.primary-menu li.current-menu-parent:hover a:hover, #site-header ul.primary-menu li.current-menu-parent:hover a:focus, #site-header ul.primary-menu li.current-menu-parent:hover > a, #site-header ul.primary-menu .current_page_item:hover a:hover, #site-header ul.primary-menu .current_page_item:hover a:focus, #site-header ul.primary-menu .current_page_item:hover > a {
      color: white;
      text-decoration: underline; }

