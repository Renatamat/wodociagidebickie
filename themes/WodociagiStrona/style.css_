.metaslider.ms-theme-cubic .flexslider ul.flex-direction-nav li a.flex-next:hover::before,
.metaslider.ms-theme-cubic .flexslider:hover ul.flex-direction-nav li a:hover:before, .metaslider.ms-theme-cubic .rslides_nav.next::before, .metaslider.ms-theme-cubic div.nivoSlider div.nivo-directionNav a.nivo-nextNav:hover::before, .metaslider.ms-theme-cubic .coin-slider .coin-slider div a.cs-next:hover::before {
