    /*height: 13px;*/
    background: #00306a;
    border: 7px solid #00306a; }
  #site-header .primary-menu-wrapper {
    background: #00306a;
    position: relative; }
    #site-header .primary-menu-wrapper span.before {
      display: block;
      content: "";
      /*width:attr(data-content)px;*/
      height: 100%;
      top: 0px;
      right: 0px;
      left: calc(100% - 1px);
      position: absolute;
      background: #00306a; }
  #site-header .primary-menu > li.menu-item > a {
    padding: 18px 0 10px;
    color: white;
    font-size: 1.6rem; }
    #site-header .primary-menu > li.menu-item > a :hover {
      color: #00a445; }
  #site-header ul.primary-menu {
    margin-left: -20px;
    justify-content: space-between;
    padding-left: 20px; }
    #site-header ul.primary-menu > li {
      margin: 0.8rem 0 0 0;
      padding: 0 1.05rem; }
      #site-header ul.primary-menu > li i.icon-home.icons {
        padding: 0 8px; }
      #site-header ul.primary-menu > li:hover {
        background: #324c81; }
        #site-header ul.primary-menu > li:hover i {
          color: #00a445; }
        #site-header ul.primary-menu > li:hover:after {
          display: block;
          content: "";
          max-width: 100%;
          width: 100%;
          height: 14px;
          left: 0px;
          position: absolute;
          background: #324c81; }
      #site-header ul.primary-menu > li:last-of-type {
        background: #00a445;
        max-width: 143px;
        text-align: center;
        position: relative; }
        #site-header ul.primary-menu > li:last-of-type:after {
          display: block;
          content: "";
          max-width: 143px;
          width: 100%;
          height: 14px;
          bottom: -13px;
          left: 0px;
          position: absolute;
          background: #00a445; }
        #site-header ul.primary-menu > li:last-of-type a {
          padding: 10px 12px 0px; }
    #site-header ul.primary-menu li.current-menu-parent a:hover, #site-header ul.primary-menu li.current-menu-parent a:focus, #site-header ul.primary-menu li.current-menu-parent > a, #site-header ul.primary-menu .current_page_item a:hover, #site-header ul.primary-menu .current_page_item a:focus, #site-header ul.primary-menu .current_page_item > a {
