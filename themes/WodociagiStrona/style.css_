@import url("https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap");
body {
  font-family: 'Poppins', "Helvetica Neue", Helvetica, sans-serif;
  color: #676767; }
  body .color-accent, body .color-accent-hover:focus, body :root .has-accent-color, body .has-drop-cap:not(:focus):first-letter, body .wp-block-button.is-style-outline, body a {
    color: #ab0f09; }
  body button, body .button, body .faux-button, body .wp-block-button__link, body .wp-block-file .wp-block-file__button, body input[type="button"], body input[type="reset"], body input[type="submit"], body .bg-accent, body .bg-accent-hover:hover, body .bg-accent-hover:focus, body :root .has-accent-background-color, body .comment-reply-link {
    background-color: #ab0f09; }

.widget_text p, .widget_text ol, .widget_text ul, .entry-content table, .widget_text dl, .widget_text dt, .widget-content .rssSummary, .entry-content {
  font-family: 'Poppins', "Helvetica Neue", Helvetica, sans-serif; }

.visuallyhidden, .hidden-label {
  border: 0;
  clip: rect(0 0 0 0);
  height: 1px;
  margin: -1px;
  overflow: hidden;
  padding: 0;
  position: absolute;
  width: 1px; }

.primary-menu-wrapper .menu-item-home {
  height: auto;
  position: relative;
  background-image: url(img/home_icon_inactive.png);
  background-position: center center;
  background-repeat: no-repeat;
  width: 45px; }

.primary-menu-wrapper .menu-item-home a {
  display: block;
  height: 100%;
  position: relative;
  z-index: 99;
  text-indent: -100000px; }

.primary-menu-wrapper .menu-item-home a:after {
  background-image: url(img/home.png);
  content: " ";
  width: 100%;
  height: 100%;
  background-repeat: no-repeat;
  background-position: center;
  position: absolute;
  left: 0;
  top: 0;
  opacity: 1;
  transition: all ease-in-out 0.3s; }

.header-titles-wrapper {
  flex: 1 0; }

.post-830 figcaption.blocks-gallery-caption,
.post-830 h3 {
  text-align: center;
  width: 100%; }

h3 {
  font-size: 1.4em; }

.header-navigation-wrapper {
  flex-direction: column;
  flex: 4 0; }

a.box-phone-contact {
  color: white;
  font-size: 16px;
  background: #2cae5e;
  padding: 10px 15px;
  text-decoration: none; }
  a.box-phone-contact:hover {
    text-decoration: underline; }

a.box-phone-contact.zglos-awarie {
  background: #ab0f09; }

.header-content-top {
  width: 100%; }

.header-content {
  width: 100%;
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 10px; }

.header-content-top-bottom, .header-content-top-top {
  display: flex;
  flex-direction: row;
  justify-content: space-between; }

form.search {
  position: relative;
  max-width: 246px; }

button.search-submit {
  background: transparent;
  position: absolute;
  top: 0;
  right: 0px;
  width: 35px;
  height: 35px;
  display: flex;
  align-items: center;
  color: #5d5d5d; }

button.search-submit:hover {
  text-decoration: none;
  color: #00306a; }

.header-footer-group pre, .header-footer-group fieldset, .header-footer-group input, .header-footer-group textarea, .header-footer-group table, .header-footer-group table *, .footer-nav-widgets-wrapper, #site-footer, .menu-modal nav *, .footer-widgets-outer-wrapper, .footer-top {
  border-color: #c0c0c0; }

.skip-link ul {
  margin: 0;
  padding: 0;
  position: absolute;
  top: 0;
  z-index: 120;
  list-style: none; }
  .skip-link ul li {
    list-style: none; }
    .skip-link ul li a {
      display: inline;
      left: -9000em;
      padding: 5px 10px;
      font-size: 1.27rem;
      position: absolute;
      text-decoration: none;
      z-index: 2;
      width: 150px;
      text-align: center; }
      .skip-link ul li a:focus, .skip-link ul li a:hover, .skip-link ul li a:active {
        background: #000;
        border: 2px solid #fff;
        color: #fff;
        left: 0;
        top: 0;
        position: absolute;
        font-weight: normal; }

input[type="text"],
input[type="password"],
input[type="email"],
input[type="url"],
