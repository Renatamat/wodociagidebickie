#site-footer {
  border: none;
  background: black;
  position: relative; }
  #site-footer .section-inner {
    justify-content: flex-end; }
  #site-footer a.to-the-top {
    width: 56px;
    line-height: 56px;
    height: 56px;
    display: block;
    text-align: center;
    background: white;
    border-radius: 5px;
    position: absolute;
    top: -13px;
    left: 50%;
    right: 50%;
    transform: translate(-50%, 0%); }
    #site-footer a.to-the-top:hover {
      text-decoration: underline; }

.footer-copyright {
