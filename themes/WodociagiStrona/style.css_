.footer-nav-widgets-wrapper {
  background: #00306a;
  color: white; }
  .footer-nav-widgets-wrapper .footer-widgets .widget-title {
    color: white;
    font-size: 2rem;
    padding-bottom: 40px;
    position: relative; }
    .footer-nav-widgets-wrapper .footer-widgets .widget-title:after {
      content: "";
      width: 66px;
