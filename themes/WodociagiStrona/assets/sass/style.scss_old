@import url('https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap');
body {
    font-family: 'Poppins', "Helvetica Neue", Helvetica, sans-serif;
    color: #676767;

.color-accent, .color-accent-hover:focus, :root .has-accent-color, .has-drop-cap:not(:focus):first-letter, .wp-block-button.is-style-outline, a{
    color: #ab0f09;
}
button, .button, .faux-button, .wp-block-button__link, .wp-block-file .wp-block-file__button, input[type="button"], input[type="reset"], input[type="submit"], .bg-accent, .bg-accent-hover:hover, .bg-accent-hover:focus, :root .has-accent-background-color, .comment-reply-link{
    background-color: #ab0f09;
}
}
.widget_text p, .widget_text ol, .widget_text ul, .entry-content table,  .widget_text dl, .widget_text dt, .widget-content .rssSummary, .entry-content{
    font-family: 'Poppins', "Helvetica Neue", Helvetica, sans-serif;
}
.visuallyhidden, .hidden-label {
    border: 0;
    clip: rect(0 0 0 0);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    width: 1px; 
}

.primary-menu-wrapper .menu-item-home{
    height: auto ; 
    position: relative;
    background-image: url(img/home_icon_inactive.png);
    background-position: center center;
    background-repeat: no-repeat;
    width: 45px;

}
.primary-menu-wrapper .menu-item-home a {
    display: block;
    height: 100%;
    position: relative;
    z-index: 99;
    text-indent: -100000px;
}
.primary-menu-wrapper .menu-item-home a:after{
    background-image: url(img/home.png);
    content: " ";
    width: 100%;
    height: 100%;
    background-repeat: no-repeat;
    background-position: center;
    position: absolute;
    left: 0;
    top: 0;
    opacity: 1;
    transition: all ease-in-out 0.3s;
}
.header-titles-wrapper{
    flex: 1 0;
}
.post-830 figcaption.blocks-gallery-caption, 
.post-830 h3{
    text-align: center;
    width: 100%;
}
h3{
    font-size: 1.4em;
}
.post-830 h3{
    
}

.header-navigation-wrapper {
    flex-direction: column;
    flex: 4 0;
}
a.box-phone-contact{
    color: white;
    font-size: 16px;
    background: #2cae5e; 
    padding: 10px 15px;
    text-decoration: none;
            &:hover{
            text-decoration: underline
        }
}
a.box-phone-contact.zglos-awarie{
    background: #ab0f09;
}
.header-content-top {
    width: 100%;
}
.header-content{
    width: 100%;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    margin-bottom: 10px;
}
.header-content-top-bottom, .header-content-top-top{
    display: flex;
    flex-direction: row;
    justify-content: space-between;
}
form.search {
    position: relative;
    max-width: 246px;
}
button.search-submit{
    background: transparent;
    position: absolute;
    top:0;
    right: 0px;
    width: 35px;
    height: 35px;
    display: flex;
    align-items: center;
    color: #5d5d5d;
}
button.search-submit:hover{
    text-decoration: none;
    color: #00306a;
}
.header-footer-group pre, .header-footer-group fieldset, .header-footer-group input, .header-footer-group textarea, .header-footer-group table, .header-footer-group table *, .footer-nav-widgets-wrapper, #site-footer, .menu-modal nav *, .footer-widgets-outer-wrapper, .footer-top{
    border-color: #c0c0c0;
}

.skip-link{
    ul{
        margin: 0;
        padding: 0;
        position: absolute;
        top: 0;
        z-index:120;
        list-style: none;
        li{
            list-style: none;
            a{
                display: inline;
                left: -9000em;
                padding: 5px 10px;
                font-size: 1.27em;
                position: absolute;
                text-decoration: none;
                z-index: 2;
                width: 150px;
                text-align: center;
                &:focus, &:hover, &:active{
                    background: #000;
                    border: 2px solid #fff;
                    color: #fff;
                    left: 0;
                    top: 0;
                    position: absolute;
                    font-weight: normal;
                }
            }
        }
    }
    
}
input[type="text"], 
input[type="password"], 
input[type="email"], 
input[type="url"], 
input[type="date"], 
input[type="month"], 
input[type="time"], 
input[type="datetime"], 
input[type="datetime-local"], 
input[type="week"], input[type="number"], 
input[type="search"], 
input[type="tel"], 
input[type="color"], textarea{
    padding: 0.8rem 1.8rem;
}
input[type="search"]{
    padding-right: 40px;
    /*padding: 1rem 40px 1rem 1.8rem;*/

}
.home .metaslider.ms-theme-cubic .flexslider ul.slides .caption-wrap, 
.home .metaslider.ms-theme-cubic .rslides .caption-wrap,
.home .metaslider.ms-theme-cubic div.nivoSlider .nivo-caption{
    background: none;
    position: absolute;
    bottom: 0;
    left: 0;
    color: white;
    opacity: 1;
    margin: 0;
    display: block;
    max-width: 890px;
    width: 100%;
    line-height: 1.4em;
    flex-direction: column;
    text-align: center;
    justify-content: center;
    bottom: 50%;
    left:50%;
    right: 50%;
    transform: translate(-50%, 40%);
}
.home .metaslider.ms-theme-cubic .flexslider ul.slides .flex-active-slide .caption-wrap,
.home .metaslider.ms-theme-cubic .rslides li[class*=rslides] .caption-wrap{
    transform: translate(-50%, 40%);
}
.metaslider .caption-wrap, .metaslider.ms-theme-cubic .flexslider ul.slides .caption-wrap {
    background: transparent !important;
}
.home .metaslider .caption-wrap .h2{
    font-size: 6rem;
    font-weight: bold;
    text-shadow: 0px 3px 3px rgba(0, 0, 0, 1);
    color: white;
}
.home .metaslider .caption-wrap p{
    font-size: 20px;
    color: white;
    text-shadow: 0px 3px 3px rgba(0, 0, 0, 1);
}
.metaslider .caption-wrap a{
    font-size: 18px;
    color: white; 
    display: inline-block;
    background: #00a445; 
    padding: 14px 22px;
    margin-top: 10px;
    text-decoration: none;
    font-weight: 500;
}
body #site-content .entry-content h3, body #site-content h3 a {
    font-size: 2rem;
    color: #00306a;
    font-family: 'Poppins', "Helvetica Neue", Helvetica, sans-serif;
    margin-top: 15px;
}
.metaslider .caption-wrap a:hover{
    background-color: #0091d2; 
    transition: all 0.5s ease;
}
.wp-block-group.sekcja_krople{
    background: #00306a;
    color: white;
    padding: 68px 0px;
}
.home .metaslider.ms-theme-cubic .flexslider ol.flex-control-nav:not(.flex-control-thumbs) li a,
.home  .metaslider.ms-theme-cubic ul.rslides_tabs li a, 
.home  .metaslider.ms-theme-cubic div.slider-wrapper .nivo-controlNav:not(.nivo-thumbs-enabled) a, 
.home  .metaslider.ms-theme-cubic .coin-slider .cs-buttons a {
    width: 69px;
    height: 8px;
    display: block;
    background: #aaaaaa;
    border-radius: 0px;
    border: none;
}
.metaslider .flex-control-paging li a.flex-active, 
.metaslider.ms-theme-cubic .flexslider ol.flex-control-nav:not(.flex-control-thumbs) li a.flex-active, 
.metaslider.ms-theme-cubic ul.rslides_tabs li:last-child a, 
.metaslider.ms-theme-cubic div.slider-wrapper div.nivo-controlNav:not(.nivo-thumbs-enabled) a:last-child,
.metaslider.ms-theme-cubic .coin-slider .cs-buttons a:last-child {
    background: #00a445;
    cursor: default;
}
.metaslider.ms-theme-cubic .flexslider:hover ul.flex-direction-nav li a, .metaslider.ms-theme-cubic .flexslider:focus-within ul.flex-direction-nav li a, .metaslider.ms-theme-cubic:hover a.rslides_nav, .metaslider.ms-theme-cubic div.nivoSlider:hover div.nivo-directionNav a, .metaslider.ms-theme-cubic .coin-slider:hover .coin-slider div a{
    background: none !important;
}
.metaslider.ms-theme-cubic .flexslider ul.flex-direction-nav li a.flex-next:hover::before,
.metaslider.ms-theme-cubic .flexslider:hover ul.flex-direction-nav li a:hover:before, .metaslider.ms-theme-cubic .rslides_nav.next::before, .metaslider.ms-theme-cubic div.nivoSlider div.nivo-directionNav a.nivo-nextNav:hover::before, .metaslider.ms-theme-cubic .coin-slider .coin-slider div a.cs-next:hover::before{   
    filter: brightness(0.5) sepia(1) saturate(10000%) hue-rotate(120deg);
}
.home .metaslider .flex-control-nav{
    bottom: 17px;
}
.metaslider .flexslider .flex-direction-nav li a{

}

h2{
    color: #00306a;
    font-size: 4.1rem;
}
.wp-block-latest-posts a, .wp-block-latest-comments__comment-meta{
    font-size: 2.0rem;
    color: #00306a;
    text-align: center;
    &:hover{
        color: #008cce;
    }
}
.home.singular .entry-header{
    padding:0px;
}

button.slick-next:before, button.slick-prev:before{
    color: #00306a;
    font-size: 35px;
    content: "\e606";
    font-family: 'simple-line-icons';
    speak: none;
    font-style: normal;
    font-weight: normal;
    font-variant: normal;
    text-transform: none;
    line-height: 1;
    -webkit-font-smoothing: antialiased;
}
button.slick-prev:before{
    content: "\e605";
}
button.slick-prev:hover:before, button.slick-prev:focus:before, button.slick-next:hover:before, button.slick-next:focus:before{
    color: #00a445;
}
.slick-slide .news-item {
    box-shadow: 0px 0px 19px rgba(0,0,0,0.1);
    z-index: 99999;
}
.slick-initialized .slick-slide{
    padding: 15px;
}
.wp-block-latest-posts.is-grid .news-item {
    border:none;
}
.home .slick-slider .news-item {
    padding: 17px;
    text-align: center;
}
.news-item img.wp-post-image {
    max-width: 330px;
    width: 100% !important;
    object-fit: cover;
    max-height: 197px;
    height: 100% !important;
}
.slick-prev, .slick-next{
    top:25%;
}

.slick-slide > div, .slick-slide > div .news-item {
    height: 100%;
}
.bip-link{
    border: 1px solid #c0c0c0;
    padding: 9px;
    display: flex;
    align-items: center;
    margin-left: 10px;
}
.header-content-top-bottom {
    margin: 10px 0 0px;
    .menu-pomocnicze{
        padding-left: 10px;
        ul{
            display: inline-flex;
            align-items: baseline;
            li{
                padding: 0 7px;
                line-height: 1.4em;
                &:hover{
                    background: #324c81;
                    a{color: white;}
                }
                a{
                    font-size: 1.3rem;
                    font-weight: normal;
                    border: none;
                }
            }
        }
    }
    ul.font-size{
        list-style: none; 
        flex-direction: row;   
        border: 1px solid #c0c0c0;
        display: inline-flex;
        padding: 0px 9px;
        align-items: baseline;
        margin: 0 ;
        li{
            margin:0px 2px;
            a{
                border: none;
                font-weight: bold;

                &.pojo-a11y-btn-resize-minus{
                    font-size: 1.3rem;
                }
                &.pojo-a11y-btn-resize-regular{
                    font-size: 1.6rem;
                }
                &.pojo-a11y-btn-resize-plus{
                    font-size: 2.4rem;
                }   
            }
        }
    }
    > a{
        padding: 2px 20px;
        line-height: 32px;
    }
    a{
        color: #5d5d5d;
        text-decoration: none;
        border: 1px solid #c0c0c0;

        &:hover{
            text-decoration: underline;
        }
    }
    .fa-facebook-f:before {
    content: "\f39e";
    color: #36508b;
}
}
.home {
 .metaslider.ms-theme-cubic .flexslider ol.flex-control-nav:not(.flex-control-thumbs) li a:hover{
    border: none;
        background: #008bcc;
    }
    .ms-theme-cubic{
        padding-bottom: 10px;
    }
    .aktualnosci_title{
        margin-bottom:0px;
    }
    .wp-block-group:not(.has-background):not(.alignwide):not(.alignfull).slider-aktualnosci{
        margin-top: -40px ;
    }
    .slick-slider .news-item {
        display: flex !important;
        flex-direction: column;
        .wp-block-latest-posts a, .wp-block-latest-comments__comment-meta{
            min-height: 2.1rem;
        }
        time {
            font-size: 1.4rem;
            color: #b2b2b2;
            font-weight: normal;
            i{
                padding-right: 5px;
            }
        }
        a.czytaj_wiecej{
            font-size: 1.6rem;
            &:hover{
                color: #008cce;
            }
        }

        .alignnone, .aligncenter{
            margin-top:0px;
            max-width: 330px;
            max-height: 197px;
            display: block;
            width: 100% !important;
            height: 100% !important;
        }
        .wp-block-latest-posts__post-excerpt {
            line-height: 25px;
            font-size: 1.5rem;
            text-align: left; 
            min-height: 10rem;

        }

    }
    .sekcja_krople{
        position: relative;
        .wp-block-columns{
            margin-top:0px;
            .alignnone, .aligncenter, .wp-block-image:not(.alignwide):not(.alignfull):not(.alignleft):not(.alignright):not(.aligncenter){
                margin:0px auto;
            }
        }
        .wp-block-group:not(.has-background):not(.alignwide):not(.alignfull){
            padding-bottom: 48px;
        }
        h2{
            color: white;
        }
        p{
            font-size: 1.4rem;
            line-height: 170%;
        }
        &:after{
            background-image: url(img/krople.png);
            content: " ";
            width: 207px;
            height: 468px;
            background-repeat: no-repeat;
            background-position: center;
            position: absolute;
            left: 3%;
            top: -87px;
            opacity: 1;
            transition: all ease-in-out 0.3s;
        }

    }
    #site-content .kafelki {
        /*margin-top: 80px !important;*/
        margin-bottom: 0px !important;
        .wp-block-group__inner-container{
            display: flex;
            flex-wrap: wrap;
            [class*="__inner-container"] > *:not(.alignwide):not(.alignfull):not(.alignleft):not(.alignright):not(.is-style-wide){
                width: 33%;
            }            
            .box_item{
                box-shadow: 0px 0px 19px rgba(0, 0, 0, 0.1);
                padding: 18px; 
                margin-bottom: 30px;
                width: calc(33% - 20px);
                margin: 10px;
                a{
                    font-size: 3rem; 
                    line-height: 4rem;
                    color: #00306a;
                    font-weight: 600;
                    display: flex;
                    flex-direction: row;
                    justify-content: space-between;
                    min-height: 3rem;
                    text-decoration: none;
                    figure.hover-img{
                        display: none;
                    }
                    .wp-block-image:not(.alignwide):not(.alignfull):not(.alignleft):not(.alignright):not(.aligncenter){
                        margin:0px;
                    }
                    &:hover{
                        color: #008cce;
                        text-decoration: underline;
                        figure{
                            display: none;
                            &.hover-img{
                                display: block;
                            }
                        }
                    }
                }
                p{
                    color: #676767;
                    font-size: 1.6rem;
                    margin-top: 23px;
                }
            }
        }
    }
    .slider-aktualnosci{
        h3{
            font-size: 2.0rem;
    color: #00306a;
    text-align: center;
     margin: 0px;
    padding: 0px;
    line-height: 1.2rem;
        }
    }
}
.single, .archive{
    .post-inner{
        padding-top: 20px;
    }

    .featured-media-inner{
        width: auto;
        float: left;
        left:unset;
    }   
    
    .featured-img-custom {
    display: inline-block;
    padding-left: 15px;
    float: left;
    max-width: max-content !important;
    margin-right: 15px;
    }
    .intro-text.section-inner{
        display: none;
    }
    .pagination-single {
        hr{
            display: none;
        }
        a{
            font-size: 1.6rem;
        }
    }
}
.archive, .search{
    .intro-text.section-inner{
        display: block;
        font-size: 1.6rem;
    }
    h3.entry-title.heading-size-1{
        font-size: 2.2rem;
        text-align: left;
        margin:3rem auto;
    }  
    hr.post-separator.styled-separator.is-style-wide.section-inner{
        display: none;
    }
    p.post-date svg.svg-icon {
        float: left;
        margin-right: 10px;
    }
}
 .search   p.post-date svg.svg-icon {
        float: left;
        margin-right: 10px;
    }
    body:not(.singular).archive, body:not(.singular).search{
        main > article:first-of-type {
            padding: 0rem 0 0;
        }
    }
body{
    overflow-x: hidden;
}
#pojo-a11y-toolbar.pojo-a11y-toolbar-left .pojo-a11y-toolbar-toggle{
    width: 38px;
    height: 38px;
}
#pojo-a11y-toolbar .pojo-a11y-toolbar-toggle a{
    width: 100%;
    height: 100%;
}

#site-header{
    hr{
        margin: -1px 0 0;
        /*height: 13px;*/
        background: #00306a;
        border:7px solid #00306a;
    }
    /*overflow: hidden;*/
    margin-top: 10px;

    .primary-menu-wrapper{
        background: #00306a;
        position: relative;
        span.before{
            display: block;
            content: "";
            /*width:attr(data-content)px;*/
            height: 100%;
            top:0px;
            right: 0px;
            left: calc(100% - 1px);
            position: absolute;
            background: #00306a;
        }
    }
    .primary-menu > li.menu-item > a{
        padding: 18px 0 10px;
        color: white;
        font-size: 1.6rem;
        :hover{
            color: #00a445;
        }
    }
    ul.primary-menu {
        margin-left: -20px;
        justify-content:space-between;
        padding-left: 20px;
        & > li{
            margin: 0.8rem 0 0 0;
            padding: 0 1.25rem; 
            i.icon-home.icons{
                padding:0 8px;
            }
            &:hover{
                background: #324c81;
                i{
                    color:#00a445;
                }
                &:after{
                    display: block;
                    content: "";
                    max-width: 100%;
                    width: 100%;
                    height: 14px;
                    left: 0px;
                    position: absolute;
                    background: #324c81;
                }
            }
            &:last-of-type{
                background: #00a445;
                max-width: 143px;
                text-align: center;
                position: relative;
                &:after{
                    display: block;
                    content: "";
                    max-width:143px;
                    width:100%;
                    height: 14px;
                    bottom: -13px;
                    left: 0px;
                    position: absolute;
                    background: #00a445;
                }
                a{
                    padding: 10px 12px 0px;
                }
            }
        }
        li.current-menu-parent, .current_page_item{
            a:hover,  a:focus, > a{
                color: #00a445;
            }
            &:hover {
                a:hover,  a:focus, > a{
                color: white;
                text-decoration: underline;
            } 
            }
        }
    }

}
.additional-flex-wrapper{
    .aside-menu{
        .widgety-sidebar{
            a{
                font-size: 1.4rem;
                text-decoration: none;
                color: #676767;
                font-weight: normal;
                &:hover{
                    color: #00306a; 
                }

                img.menu-image.menu-image-title-after, .menu-image-hover-wrapper img.hovered-image {
                    width: 45px;
                }
                .menu-image-hover-wrapper img.hovered-image {
                    margin-left: -45px !important;
                }
            }
        }
    }
}
