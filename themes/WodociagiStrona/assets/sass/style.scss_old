.footer-nav-widgets-wrapper{
    background: #00306a;
    color: white;
    .footer-widgets{
        .widget-title{
            color: white; 
            font-size: 2rem;
            padding-bottom: 40px;
            position: relative;
            &:after {
                content: "";
                width: 66px;
                height: 1px;
                background: #00a445;
                position: absolute;
                left: 0px;
                bottom: 0px; 
            }
        }
        a, p{
            color: white;
            font-size: 1.4rem; 
            font-weight: normal;
            text-decoration: none;
