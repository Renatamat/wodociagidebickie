		#cd-timeline::before, .cd-timeline::before {
			background: #00306a;
		}
		#cd-timeline .cd-timeline-content, .cd-timeline .cd-timeline-content {
			background: #ffffff;
			-webkit-box-shadow: 0 3px 0 transparent;
			-moz-box-shadow: 0 3px 0 transparent;
			box-shadow: 0 3px 0 transparent;
		}
		.cd-timeline-block:nth-child(odd) .cd-timeline-content::before {
				border-left-color: #ffffff;
			}
			.cd-timeline-block:nth-child(even) .cd-timeline-content::before {
				border-right-color: #ffffff;
			}
			@media only screen and (max-width: 821px) {
				.cd-timeline-content::before {
					border-left-color: transparent;
					border-right-color: #ffffff;
				}
				.cd-timeline-block:nth-child(odd) .cd-timeline-content::before {
					border-left-color: transparent;
				}
			}

		#cd-timeline::before, .cd-timeline::before {
			background: #00306a;
		}
		#cd-timeline .cd-timeline-content, .cd-timeline .cd-timeline-content {
			background: #ffffff;
			-webkit-box-shadow: 0 3px 0 transparent;
			-moz-box-shadow: 0 3px 0 transparent;
			box-shadow: 0 3px 0 transparent;
		}
		.cd-timeline-block:nth-child(odd) .cd-timeline-content::before {
				border-left-color: #ffffff;
			}
			.cd-timeline-block:nth-child(even) .cd-timeline-content::before {
				border-right-color: #ffffff;
			}
			@media only screen and (max-width: 821px) {
				.cd-timeline-content::before {
					border-left-color: transparent;
					border-right-color: #ffffff;
				}
				.cd-timeline-block:nth-child(odd) .cd-timeline-content::before {
					border-left-color: transparent;
				}
			}
    #cd-timeline.cd-container, .cd-timeline.cd-container{
        .cd-timeline-title-container .timeline-date{
            display: none;
        }
        &:before{
          background: #00306a;
        }

        h2.cd-timeline-item-title{
            font-size: 1.6rem;
            color:  #00306a;
        }
        .cd-timeline-content{
            box-shadow: none;
            border: 1px solid #00963f;
            border-radius: 0px;
            background: white;
            .the-excerpt{
                p{
                    font-size: 1.2rem;
                }
            }
        }
        .cd-timeline-img{
            box-shadow: none;
            width: 34px;
            margin-left: -17px;
            height: 34px;
            border: 1px solid #00963f;
            margin-top: 17px;
        }
        span.fa{
            color: #00306a;
            font-size: 15px;
            line-height: 34px;
            position: relative; 
            .year{
                position: absolute;            
                line-height: 34px;
                color: #00306a;
                font-family: 'Poppins', "Helvetica Neue", Helvetica, sans-serif;
                font-size: 1.6rem;
                width: 50px;
            }
        }
        .cd-timeline-block:nth-child(odd){
            span.fa{ 
                .year{
                     left: 45px;
                }
            }
        }
        .announcement-banner-image{
            border-radius: 0px;
                margin: 0 auto;
            margin-top: 20px;
        }
        .cd-timeline-block:nth-child(even){
            span.fa{ 
                .year{
                     left: -50px;
                }
            }
        }
         
        .cd-timeline-block:nth-child(odd) .cd-timeline-content::before{
            border-left-color: #00963f;
        }
        .cd-timeline-block:nth-child(even) .cd-timeline-content::before {
            border-right-color: #00963f;
        }
/*        .cd-timeline-content::before{
            border-color: transparent transparent transparent #00963f;
        }*/
    }
    .historia  .c-accordion__title{
        text-align: center;
        font-size: 2.7rem;
        margin: 2rem auto 3rem;
        font-weight: normal;
        &:before{
            content: "\f073";
            margin-left: 5px;
            transition: transform 1s;
            display: inline-block;
            font-family: "Font Awesome 5 Free";
            position: absolute; 
            left: calc(50% - 94px);
        }
        
        &:after{
            display: none;
        }
        
    }
   
    @media only screen and (min-width: 822px){
        #cd-timeline.cd-container, .cd-timeline.cd-container{ 
            .cd-timeline-content{
                     width: 45.5%;
            }
        }
}
      
@media  only screen and (min-width:600px)  and (max-width: 1024px)  {

		/* Force table to not be like tables anymore */
/*		table, thead, tbody, th, td, tr {
			display: inline-block;
		}*/
    }
    @media screen and (max-width: 1000px){
        .menu-modal-inner{
            background:#00306a;
              .menu-top {
                a, .toggle{
                 color: white;             
                }
              }

        }
         form.search{
                  max-width: 100%;
              }
        .search-modal .search-submit{
                  right:0px;
              }
        
    }
    @media screen and (max-width: 822px){
        #cd-timeline.cd-container, .cd-timeline.cd-container {
        .cd-timeline-block:nth-child(odd) .cd-timeline-content::before{
            border-left-color: transparent;
            border-right-color: #00963f;
        }
         .cd-timeline-block:nth-child(odd) span.fa .year{
            left: -50px;
        }
         .cd-timeline-img{
            margin-left: 7px;        
        }
        }
    }
@media screen and (max-width: 768px) {
    table {
        border: 0;
    }
    .wp-block-table.is-style-stripes td{
        border-right: none;
    }

    table caption {
        font-size: 1.3em;
    }

    table thead {
        border: none;
        clip: rect(0 0 0 0);
        height: 1px;
        margin: -1px;
        overflow: hidden;
        padding: 0;
        position: absolute;
        width: 1px;

    }

    table tr {
        border-bottom: 3px solid #ddd;
        display: block;
        margin-bottom: .625em;
    }

    table td {
        border-bottom: 1px solid #ddd;
        display: block;
        font-size: .8em;
        text-align: right;
        display: flex;
        justify-content: space-between;
    }

    table td::before {
        /*
        * aria-label has no advantage, it won't be read inside a table
        content: attr(aria-label);
        */
        text-align: left;
        max-width: 50%;
        content: attr(data-label);
        float: left;
        font-weight: bold;
        text-transform: uppercase;
    }
    table td.attachment-title::before {
       display: none; 
    }
    table td.attachment-size::before{
        padding-right: 10px;
    }
    table td:last-child {
        border-bottom: 0;
    }
        .download-attachments table.da-attachments-table td{
        text-align: right;
        display: flex;
        justify-content: end;
    }
    
    
    
    
}  

@media (max-width: 1650px){
    .home .sekcja_krople:after, #site-header .primary-menu-wrapper:before{
        display: none; 
    }

}
@media (max-width: 1200px){
    .sekcja_krople p{
        padding: 0 25px;
    }
    .site-logo img{
        margin: 10px;
    }
       body.template-przetargi, body.template-bip, body.category-przetargi,body.template-strefaklienta, body.category-komunikaty-internetowe-biuro-obslugi-klienta{
        #site-content
        {
            div.additional-flex-wrapper{
                padding: 0 15px;
            }
        }
       }
}
@media (max-width:1150px){
    .header-content-top-bottom{
        flex-wrap: wrap;
        justify-content: flex-end;
        > * {
            order: 1; 
            margin-left: 10px;
        } 
        .menu-pomocnicze{
            flex: 1;
        }
        .search{
            order:2;
            max-width: 100%;
            width: 100%;
            /*flex:1;*/
            margin: 10px 0 0 0;
        }
    }
    .home #site-content .kafelki .wp-block-group__inner-container .box_item a
    {font-size: 2.6rem;
     span{
         max-width: 30%;
     }
    }


}
@media (max-width:1150px) and (min-width: 1000px){
    #site-header ul.primary-menu {
        justify-content: space-around;
        > li:last-of-type{
            max-width: 100%;
            &:after{
                max-width: 100%;

            }
        }
    }
}
@media (max-width:1000px){
    .page-template-template-badanie-wody{
.wp-block-columns.badanie-wskazniki-border {
    display: flex;
    flex-direction: column;
}
.wp-block-column:not(:first-child){
    margin-left: 0;
}
