        list-style-position: inside;
        color: white; 
        ::marker{
            color: white;
        }
        li{
            /*padding-left:10px;*/
        }
    }
}    
#site-footer {
    border: none;
    background: black; 
    position: relative;
    .section-inner {
        justify-content: flex-end;
    }
    a.to-the-top{
        width: 56px;
        line-height: 56px;
        height: 56px;
        display: block;
        text-align: center;
        background: white;
        border-radius: 5px;
        position: absolute;
        top: -13px;
        left:50%;
        right: 50%;
        transform: translate(-50%, 0%);
        &:hover{
            text-decoration: underline;
        }
    }
}
.footer-copyright{
    font-weight: normal;
    font-size: 1.2rem;
    color: #64646a;
    text-align: right;
}

