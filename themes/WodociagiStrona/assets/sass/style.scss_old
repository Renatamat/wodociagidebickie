        }
        a{
            /*font-size: 1.6rem;*/
            /*padding: 10px 15px;*/
        }
    }
}
@media (max-width: 992px){
    .footer-widgets-wrapper{
        flex-wrap: wrap;
        width: 100%;
        margin-left: 0px;
        display: flex;
        .footer-widgets {
            margin-bottom: 4rem;
            width: calc(50% - 5rem);
        }
    }
    .footer-top-visible .footer-nav-widgets-wrapper, .footer-top-hidden #site-footer{
        margin-top: 5rem;
    }
    .footer-nav-widgets-wrapper .bip{
        max-width: fit-content;
        img{
            padding: 5px 20px;
        }
    }
}
@media (min-width:700px){
    .additional-flex-wrapper{
        .widget .widget-title{
            font-size: 1.2em;
        }
    }
    .metaslider .slides img{
    max-height: 509px !important;
    object-fit: cover;
}
    .archive .archive-header-inner.section-inner{
         h2{
            text-align: center;
            font-size: 3rem;
        }
    }
    .category-przetargi, .template-przetargi, .template-bip, .template-strefaklienta , .category-komunikaty-internetowe-biuro-obslugi-klienta{
        .section-inner, .additional-flex-wrapper{
        padding: 0;
    }
    }
    .wp-block-group__inner-container, .entry-content .wp-block-group p, .wrapper, .section-inner, .additional-flex-wrapper {
        max-width: 1200px;
        width: 100%;
        padding: 0 15px;
    }
    .entry-content > *:not(.alignwide):not(.alignfull):not(.alignleft):not(.alignright):not(.is-style-wide),.breadcrumb{
        max-width: 1200px;
        width: 100%;
        padding: 0 15px;
    }

    [class*="__inner-container"] > *:not(.alignwide):not(.alignfull):not(.alignleft):not(.alignright):not(.is-style-wide) {
        max-width: 100%;
        width: 100%;
    }
}
@media (max-width: 700px){
    .footer-widgets-wrapper .footer-widgets {
        margin-top: 0px;
        width: calc(50% - 0rem);
    }
    .single , .archive
    {
        .featured-media-inner{
        display: flex;
        justify-content: center;
        float: none;
         img{
            margin: 0;
        }
    }
    }
    body.template-przetargi, body.template-bip, body.category-przetargi, body.template-strefaklienta, body.category-komunikaty-internetowe-biuro-obslugi-klienta, body{
        #site-content
        {
            div.additional-flex-wrapper{
                flex-direction: column-reverse;
                padding: 0 15px;
                .section-inner{
                    width: 100%;
                }
                .menu-right{
                    max-width: 100%;
                    .custom-menu-class,  > .h2{
                     display: none;
                    }
                }
                article > header, article .entry-content p{
