    &::before, &::after{
        display: none;
    } 
}
body[class*="pojo-a11y-resize-font"]{
    .header-content-top-bottom .menu-pomocnicze ul li a{
        font-size:1.8rem;
    } 
    .search button{
            font-size: 130%;
    }
    .header-content-top-bottom a, 
    a.box-phone-contact{
        font-size: large;

    }
    #site-header .primary-menu > li.menu-item > a, table tr td{
        font-size: inherit;
    }
    .breadcrumb ol li, .breadcrumb ol a, .breadcrumb li span a{
        font-size: 2rem;
        line-height: auto;
    }
    .search{
        h2.entry-title{
            font-size: inherit;  
        }
    }
    .header-content-top-bottom ul.font-size li a.pojo-a11y-btn-resize-minus{
        font-size: 1.6rem;
    }
    .header-content-top-bottom ul.font-size li a.pojo-a11y-btn-resize-regular{
        font-size: 2.0rem;
    }
    .header-content-top-bottom ul.font-size li a.pojo-a11y-btn-resize-plus{
        font-size: 2.8rem;
    }
     #site-content h1.entry-title{
       font-size: 4rem; 
    }
    &.home .metaslider .caption-wrap p{
        font-size: 3rem !important;
    }
    &.home .metaslider .caption-wrap .h2 {
        font-size: 6rem !important;
    }
    .wp-block-latest-posts a, .wp-block-latest-comments__comment-meta, 
    &.home .slick-slider .news-item .wp-block-latest-posts__post-excerpt, 
    &.home .slick-slider .news-item a.czytaj_wiecej, 
    .footer-nav-widgets-wrapper .footer-widgets a, .footer-nav-widgets-wrapper .footer-widgets p
    {
        font-size: inherit;
        line-height: inherit;
    }
    #site-header ul.primary-menu > li:last-of-type, #site-header ul.primary-menu > li:last-of-type:after{
        max-width: 100%;
    }
    &.home #site-content .kafelki .wp-block-group__inner-container .box_item a{
        font-size: 5rem;
        flex-direction: column-reverse;
        text-align: center;
        line-height: inherit;
        span{
            margin: 0 auto;
        }
    }
    .header-content-top-bottom{
        flex-wrap: wrap;
        justify-content: flex-end;
        > * {
            order: 1; 
            margin-left: 10px;
        } 
        .menu-pomocnicze{
            flex: 1;
        }
        .search{
            order:2;
            max-width: 100%;
            width: 100%; 
            /*flex:1;*/
            margin: 10px 0 0 0;
        }
        
    }
    .search h2.entry-title{
        font-size: 5rem !Important;
    }
}
body.pojo-a11y-high-contrast figure.wp-block-image img{
    background: transparent !important;
    background-color: transparent !important;
}
body.pojo-a11y-negative-contrast, body.pojo-a11y-high-contrast{
    figure.wp-block-image.size-large:not(.hover-img) {
        filter: sepia(12%) brightness(700%) contrast(114%);
    }
    .metaslider ol.flex-control-nav.flex-control-paging{
