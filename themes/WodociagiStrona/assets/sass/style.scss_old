    .metaslider.ms-theme-cubic .flexslider ul.slides .caption-wrap, .metaslider.ms-theme-cubic .rslides .caption-wrap, .metaslider.ms-theme-cubic div.nivoSlider .nivo-caption{
        background: none !important;
    }
}
body:not(.home):not(.search) #site-content{   
    .entry-header{
        padding: 3.6rem 0px;
    }
    h1.entry-title,  h2.entry-title{
        font-size: 3rem;
        color: #00306a;

    }
    .entry-content{

        font-size: 1.5rem;
        color: #676767;


/*        > p:first-of-type{
            color: #00306a;
            font-size: 2rem;
        }*/

    }
}
.breadcrumb{
    margin:26px  auto 0;
    ol{
        list-style: none;
        margin:0px;
        display: inline-flex;
        flex-wrap: wrap;

        li, a{
            color: #7e7e7e;
            font-size: 1.3rem;
            text-decoration: none;          
        }
        li{
            margin-left: 10px;
        }
        a:hover{
            text-decoration: underline;
        }
    }
}

table {
    border: 1px solid #ccc;
    border-collapse: collapse;
    margin: 0;
    padding: 0;
    width: 100%;
    table-layout: auto;
    thead tr{
        background: #00306a;
        color: white;
        th{
            font-weight: normal;
            font-size: 1.6rem;
            text-transform: none;
        }
    }
}
.wp-block-table.is-style-stripes td{
    border-right-color: #dcdcda;
}
table caption {
    font-size: 1.5em;
    margin: .5em 0 .75em;
}

table tr {
    background-color: white;
    border: 1px solid #ddd;
    padding: .35em;
    td{
        font-size: 1.4rem;
    }
}
.entry-content .wp-block-table.is-style-stripes tbody tr
{
    &:nth-child(even){
        background-color: #f4f4f4;
    }
    &:nth-child(odd){
        background-color: white;
    }
}

table th,
table td {
    padding: .625em;
    text-align: center;
}

table th {
    font-size: 1.4rem;
    letter-spacing: .1em;
    text-transform: uppercase;
}

.additional-flex-wrapper {
    margin: 0 auto;
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    aside{
        width: 23%;
        min-width: 258px;
    }
}
.metaslider.ms-theme-cubic .flexslider ul.slides .caption-wrap, .metaslider.ms-theme-cubic .rslides .caption-wrap, .metaslider.ms-theme-cubic div.nivoSlider .nivo-caption{
    background-color: transparent !important;
}
.search{
    h2.entry-title{
        font-size: 4rem;
    }
    .post-inner{
        padding-top:1em;
    }
    p{
        font-size:1.6rem;
    }
}
.single .post-meta , .archive .post-meta
{
    li.post-author, li.post-comment-link{
        display: none;
    }

}
.archive{
    .entry-content{
      .featured-media{
            max-width: 300px;
}
    }
}
.page-id-27{
    aside.bip-menu.aside-menu.menu-right{
        display: none;
    }
}

.pagination {
    .nav-links {
    justify-content: center;
    > *{
        border: 1px solid #d5d5d5;
        font-size: 14px;
        min-width: 30px;
        color: black;
        text-align: center;
        line-height: 30px;
        margin: 50px 3px;
    } 
    span.page-numbers.current{
            color: white;
            background: #00306a;
        }
    }
    .dots{
        transform: none;
    }
    .prev, .next{
    margin: 0;
    color: #d5d5d5;
    }
}
