        border: 2px solid #0071a1;
    margin: 0px 16px;
    padding-right: 70px;
    margin-top: -10px; 
    width: calc(100% - 31px) !important;}*/
.wp-block-column{
    .c-accordion__item{
      
        h3{
            padding-left:75px;
            text-align: left;
            position: relative;
                padding-right: 30px;
                min-height: 37px;
          &:before{
            display: block;
            content:"";
            background: url(img/12.png) no-repeat;
            /*background-size: 100%;*/
           
            height: 43px;
            top:0;
            left: 0;
            bottom: 0;
            right: 0;
            width: 57px;
            position: absolute;
            left:10px;
                }
        }
        &.studnia {
            h3:before{
                 background: url(img/10.png) no-repeat;
                     margin-left: 10px;
            }

        }
        &.nowa-dzialalnosc {
